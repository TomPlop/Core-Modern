            "age": "1"
        }
    },
    {
        "apply": {"model": "tfg:block/plant/red_oat_grass_short_tuft"},
        "when": {
            "stage": "1",
            "age": "2"
        }
    },
    {
        "apply": {"model": "tfg:block/plant/red_oat_grass_tuft"},
        "when": {
            "stage": "1",
            "age": "3"
        }
    }
]}
